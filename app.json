      },
      "edgeToEdgeEnabled": true,
      "package": "com.barindam.LmsApp"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "9baafae2-ef19-4646-abfe-00734d387d6c"
      }
